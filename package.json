{
  "name": "terminus",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "worker"
  ],
  "scripts": {
    "dev": "next dev",
    "generate-feed": "tsx scripts/generate-feed.ts",
    "build": "tsx scripts/generate-feed.ts && next build",
    "build:cf": "npx @opennextjs/cloudflare build",
    "start": "next start",
    "lint": "eslint",
    "deploy": "npm run build:cf && npx wrangler pages deploy .open-next/assets --project-name terminus-ink",
    "prepare": "husky"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@supabase/supabase-js": "^2.102.1",
    "next": "^16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
