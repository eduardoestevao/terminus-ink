{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@terminus/core": ["../packages/core/src"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
